						<yjs:TableNodeStyle.backgroundStyle>
							<yjs:ShapeNodeStyle fill="{y:GraphMLReference 2}"/>
						</yjs:TableNodeStyle.backgroundStyle>
						<yjs:TableNodeStyle.table>
							<yx:Table Padding="30,0,0,0">
								<yx:Table.Rows>
									<yx:Row MinimumSize="10" Size="90" Padding="50,0,0,0" Style="{y:GraphMLReference 4}">
										<yx:Row.Labels>
											<y:Label Text="Intranet" LayoutParameter="{x:Static yx:StretchStripeLabelModel.Left}" Style="{y:GraphMLReference 3}" PreferredSize="41,14"/>
										</yx:Row.Labels>
									</yx:Row>
									<yx:Row MinimumSize="10" Size="90" Padding="50,0,0,0" Style="{y:GraphMLReference 4}">
										<yx:Row.Labels>
											<y:Label LayoutParameter="{x:Static yx:StretchStripeLabelModel.Left}" Style="{y:GraphMLReference 3}" PreferredSize="55,32">
												<y:Label.Text><![CDATA[Word
Processor]]></y:Label.Text>
											</y:Label>
										</yx:Row.Labels>
									</yx:Row>
									<yx:Row MinimumSize="10" Size="90" Padding="50,0,0,0" Style="{y:GraphMLReference 4}">
										<yx:Row.Labels>
											<y:Label Text="Manual" LayoutParameter="{x:Static yx:StretchStripeLabelModel.Left}" Style="{y:GraphMLReference 3}" PreferredSize="40,14"/>
										</yx:Row.Labels>
									</yx:Row>
									<yx:Row MinimumSize="10" Size="90" Padding="50,0,0,0" Style="{y:GraphMLReference 4}">
										<yx:Row.Labels>
