<graphml xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://www.yworks.com/xml/schema/graphml.html/2.0/ygraphml.xsd " xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:bpmn="http://www.yworks.com/xml/yfiles-bpmn/2.0" xmlns:yx="http://www.yworks.com/xml/yfiles-common/4.0" xmlns:y="http://www.yworks.com/xml/yfiles-common/3.0" xmlns:x="http://www.yworks.com/xml/yfiles-common/markup/3.0" xmlns:yjs="http://www.yworks.com/xml/yfiles-for-html/3.0/xaml" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<key id="d0" for="node" attr.type="boolean" attr.name="Expanded" y:attr.uri="http://www.yworks.com/xml/yfiles-common/2.0/folding/Expanded">
		<default>true</default>
	</key>
	<key id="d1" for="node" attr.name="NodeLabels" y:attr.uri="http://www.yworks.com/xml/yfiles-common/2.0/NodeLabels"/>
	<key id="d2" for="node" attr.name="NodeGeometry" y:attr.uri="http://www.yworks.com/xml/yfiles-common/2.0/NodeGeometry"/>
	<key id="d3" for="all" attr.name="UserTags" y:attr.uri="http://www.yworks.com/xml/yfiles-common/2.0/UserTags"/>
	<key id="d4" for="node" attr.name="NodeStyle" y:attr.uri="http://www.yworks.com/xml/yfiles-common/2.0/NodeStyle"/>
	<key id="d5" for="node" attr.name="NodeViewState" y:attr.uri="http://www.yworks.com/xml/yfiles-common/2.0/folding/1.1/NodeViewState"/>
	<key id="d6" for="edge" attr.name="EdgeLabels" y:attr.uri="http://www.yworks.com/xml/yfiles-common/2.0/EdgeLabels"/>
	<key id="d7" for="edge" attr.name="EdgeGeometry" y:attr.uri="http://www.yworks.com/xml/yfiles-common/2.0/EdgeGeometry"/>
	<key id="d8" for="edge" attr.name="EdgeStyle" y:attr.uri="http://www.yworks.com/xml/yfiles-common/2.0/EdgeStyle"/>
	<key id="d9" for="edge" attr.name="EdgeViewState" y:attr.uri="http://www.yworks.com/xml/yfiles-common/2.0/folding/1.1/EdgeViewState"/>
	<key id="d10" for="port" attr.name="PortLabels" y:attr.uri="http://www.yworks.com/xml/yfiles-common/2.0/PortLabels"/>
	<key id="d11" for="port" attr.name="PortLocationParameter" y:attr.uri="http://www.yworks.com/xml/yfiles-common/2.0/PortLocationParameter">
		<default>
			<x:Static Member="y:FreeNodePortLocationModel.NodeCenterAnchored"/>
		</default>
	</key>
	<key id="d12" for="port" attr.name="PortStyle" y:attr.uri="http://www.yworks.com/xml/yfiles-common/2.0/PortStyle">
		<default>
			<x:Static Member="y:VoidPortStyle.Instance"/>
		</default>
	</key>
	<key id="d13" for="port" attr.name="PortViewState" y:attr.uri="http://www.yworks.com/xml/yfiles-common/2.0/folding/1.1/PortViewState"/>
	<key id="d14" attr.name="SharedData" y:attr.uri="http://www.yworks.com/xml/yfiles-common/2.0/SharedData"/>
	<data key="d14">
		<y:SharedData>
			<yjs:Font x:Key="1" fontSize="12"/>
			<yjs:Color x:Key="2" value="#FFE0E0E0"/>
			<yjs:LabelStyle x:Key="3" verticalTextAlignment="CENTER" horizontalTextAlignment="CENTER" font="{y:GraphMLReference 1}"/>
			<bpmn:AlternatingLeafStripeStyle x:Key="4">
				<bpmn:AlternatingLeafStripeStyle.evenLeafDescriptor>
					<bpmn:StripeDescriptor backgroundFill="#FFC4D7ED" insetFill="{y:GraphMLReference 2}"/>
				</bpmn:AlternatingLeafStripeStyle.evenLeafDescriptor>
				<bpmn:AlternatingLeafStripeStyle.parentDescriptor>
					<bpmn:StripeDescriptor backgroundFill="#FF7192B2" insetFill="{y:GraphMLReference 2}"/>
				</bpmn:AlternatingLeafStripeStyle.parentDescriptor>
				<bpmn:AlternatingLeafStripeStyle.oddLeafDescriptor>
					<bpmn:StripeDescriptor backgroundFill="#FFABC8E2" insetFill="{y:GraphMLReference 2}"/>
				</bpmn:AlternatingLeafStripeStyle.oddLeafDescriptor>
			</bpmn:AlternatingLeafStripeStyle>
			<yjs:ShapeNodeStyle x:Key="5" fill="TRANSPARENT"/>
			<yx:InteriorNodeLabelModel x:Key="6"/>
			<yjs:LabelStyle x:Key="7" verticalTextAlignment="CENTER" horizontalTextAlignment="CENTER" font="{y:GraphMLReference 1}"/>
			<bpmn:BpmnEdgeStyle x:Key="8"/>
			<bpmn:BpmnEdgeStyle x:Key="9" type="DIRECTED_ASSOCIATION"/>
		</y:SharedData>
	</data>
	<graph id="G" edgedefault="directed">
		<node id="n0">
			<data key="d1">
				<x:List>
					<y:Label Text="Workflow Details Table" LayoutParameter="{x:Static bpmn:PoolHeaderLabelModel.WEST}" PreferredSize="122,14">
						<y:Label.Style>
							<yjs:LabelStyle font="{y:GraphMLReference 1}"/>
						</y:Label.Style>
					</y:Label>
				</x:List>
			</data>
			<data key="d2">
				<y:RectD X="-50" Y="-312.5" Width="455" Height="322.5"/>
			</data>
			<data key="d4">
				<bpmn:PoolNodeStyle>
					<yjs:TableNodeStyle tableRenderingOrder="ROWS_FIRST">
						<yjs:TableNodeStyle.backgroundStyle>
							<yjs:ShapeNodeStyle fill="{y:GraphMLReference 2}"/>
						</yjs:TableNodeStyle.backgroundStyle>
						<yjs:TableNodeStyle.table>
							<yx:Table Padding="20,0,0,0">
								<yx:Table.Rows>
									<yx:Row MinimumSize="10" Size="100" Padding="20,0,0,0" Style="{y:GraphMLReference 4}">
										<yx:Row.Labels>
											<y:Label Text="Administration" LayoutParameter="{x:Static yx:StretchStripeLabelModel.Left}" Style="{y:GraphMLReference 3}" PreferredSize="77,14"/>
										</yx:Row.Labels>
									</yx:Row>
									<yx:Row MinimumSize="10" Size="120" Padding="20,0,0,0" Style="{y:GraphMLReference 4}">
										<yx:Row.Labels>
											<y:Label Text="Management" LayoutParameter="{x:Static yx:StretchStripeLabelModel.Left}" Style="{y:GraphMLReference 3}" PreferredSize="71,14"/>
										</yx:Row.Labels>
									</yx:Row>
									<yx:Row MinimumSize="10" Size="102.5" Padding="20,0,0,0" Style="{y:GraphMLReference 4}">
										<yx:Row.Labels>
											<y:Label Text="Webserver" LayoutParameter="{x:Static yx:StretchStripeLabelModel.Left}" Style="{y:GraphMLReference 3}" PreferredSize="58,14"/>
										</yx:Row.Labels>
									</yx:Row>
								</yx:Table.Rows>
								<yx:Table.Columns>
									<yx:Column MinimumSize="10" Size="415">
										<yx:Column.Style>
											<yjs:NodeStyleStripeStyleAdapter nodeStyle="{y:GraphMLReference 5}"/>
										</yx:Column.Style>
									</yx:Column>
								</yx:Table.Columns>
								<yx:Table.RowDefaults>
									<yx:StripeDefaults Padding="20,0,0,0" Style="{y:GraphMLReference 4}">
										<yx:StripeDefaults.Labels>
											<y:LabelDefaults AutoAdjustPreferredSize="true" ShareLayoutParameterInstance="true" LayoutParameter="{x:Static yx:StretchStripeLabelModel.Left}" Style="{y:GraphMLReference 3}" ShareStyleInstance="true"/>
										</yx:StripeDefaults.Labels>
									</yx:StripeDefaults>
								</yx:Table.RowDefaults>
								<yx:Table.ColumnDefaults>
									<yx:StripeDefaults Padding="0,30,0,0">
										<yx:StripeDefaults.Labels>
											<y:LabelDefaults AutoAdjustPreferredSize="true" ShareLayoutParameterInstance="true" LayoutParameter="{x:Static yx:StretchStripeLabelModel.Top}" ShareStyleInstance="true">
												<y:LabelDefaults.Style>
													<yjs:LabelStyle verticalTextAlignment="CENTER" horizontalTextAlignment="CENTER" font="{y:GraphMLReference 1}"/>
												</y:LabelDefaults.Style>
											</y:LabelDefaults>
										</yx:StripeDefaults.Labels>
										<yx:StripeDefaults.Style>
											<yjs:NodeStyleStripeStyleAdapter nodeStyle="{y:GraphMLReference 5}"/>
										</yx:StripeDefaults.Style>
									</yx:StripeDefaults>
								</yx:Table.ColumnDefaults>
							</yx:Table>
						</yjs:TableNodeStyle.table>
					</yjs:TableNodeStyle>
				</bpmn:PoolNodeStyle>
			</data>
			<graph id="n0:" edgedefault="directed">
				<node id="n0::n0">
					<data key="d2">
